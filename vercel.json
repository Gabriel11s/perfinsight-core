{
  "rewrites": [
    { "source": "/((?!assets|bundle-v3\\.js|favicon\\.ico|robots\\.txt|countries-110m\\.json|placeholder\\.svg).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/embed(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://*.gohighlevel.com https://*.leadconnectorhq.com https://*.msgsndr.com https://*.highlevel.com *" }
      ]
    },
    {
      "source": "/((?!embed).*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
